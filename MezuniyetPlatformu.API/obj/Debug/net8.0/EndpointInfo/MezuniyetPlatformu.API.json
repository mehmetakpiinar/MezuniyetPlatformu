  "components": {
    "schemas": {
      "CreateJobPostingDto": {
        "required": [
          "description",
          "jobType",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "jobType": {
            "minLength": 1,
            "type": "string"
          },
          "deadline": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateMessageDto": {
        "required": [
          "content",
          "recipientUserId"
        ],
        "type": "object",
        "properties": {
          "recipientUserId": {
            "type": "integer",
            "format": "int32"
          },
          "content": {
            "maxLength": 1000,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreatePostDto": {
        "required": [
          "content",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "content": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "email",
          "sifre"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "sifre": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "required": [
          "email",
          "firstName",
          "lastName",
          "password",
          "userTypeId"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "userTypeId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UpdateJobPostingDto": {
        "required": [
          "description",
          "isActive",
          "jobType",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "jobType": {
            "minLength": 1,
            "type": "string"
          },
          "deadline": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "UpdatePostDto": {
        "required": [
          "content",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "content": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "profilePhotoURL": {
            "type": "string",
            "nullable": true
          },
          "about": {
            "type": "string",
            "nullable": true
          },
          "graduationYear": {
            "type": "integer",
            "format": "int32"
          },
          "studyProgram": {
            "type": "string",
            "nullable": true
          },
          "linkedInURL": {
            "type": "string",
            "nullable": true
          },
          "gitHubURL": {
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
