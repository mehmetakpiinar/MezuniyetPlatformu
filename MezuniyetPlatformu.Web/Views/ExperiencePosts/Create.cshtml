@model MezuniyetPlatformu.Web.ViewModels.CreatePostViewModel
@{
    ViewData["Title"] = "Gönderi Oluştur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="m-0 fw-bold">Deneyim Paylaş</h5>
                </div>
                <div class="card-body p-4">

                    <form asp-action="Create" method="post" enctype="multipart/form-data">

                        <div class="mb-3">
                            <input asp-for="Title" class="form-control form-control-lg border-0 px-0 fw-bold" placeholder="Konu başlığı ne?" style="font-size: 1.2rem;" />
                            <hr class="m-0">
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <textarea asp-for="Content" class="form-control border-0 px-0 rich-text" rows="6" placeholder="Nelerden bahsetmek istersin? Mülakat süreci, maaş, ofis ortamı..."></textarea>
                            <span asp-validation-for="Content" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted"><i class="fa-regular fa-image me-1"></i> Görsel Ekle (Opsiyonel)</label>
                            <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*">
                        </div>

                        <div class="d-flex justify-content-end align-items-center">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4 me-2 fw-bold text-secondary">Vazgeç</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Paylaş</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            // Summernote varsa aktifleştir, yoksa düz textarea kalır
            if($('.rich-text').length > 0 && typeof $.fn.summernote !== 'undefined') {
                $('.rich-text').summernote({
                    placeholder: 'Deneyimlerini yaz...',
                    tabsize: 2,
                    height: 200,
                    toolbar: [
                      ['style', ['bold', 'italic', 'underline', 'clear']],
                      ['para', ['ul', 'ol']]
                    ]
                });
            }
        });
    </script>
}