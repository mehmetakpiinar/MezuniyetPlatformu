@model IEnumerable<MezuniyetPlatformu.Web.ViewModels.ExperiencePostViewModel>
@{
    ViewData["Title"] = "Akış";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-3 d-none d-lg-block">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body text-center">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
                            <i class="fa-solid fa-user fa-xl text-secondary"></i>
                        </div>
                        <h6 class="fw-bold text-dark">@User.Identity.Name</h6>
                        <a asp-controller="ExperiencePosts" asp-action="Create" class="btn btn-sm btn-outline-primary rounded-pill w-100 mt-2">
                            <i class="fa-solid fa-plus me-1"></i> Yeni Gönderi
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-6">

            <div class="d-lg-none mb-3">
                <a asp-controller="ExperiencePosts" asp-action="Create" class="btn btn-primary w-100 fw-bold rounded-pill">
                    <i class="fa-solid fa-pen me-2"></i> Deneyim Paylaş
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa-regular fa-newspaper fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Akış henüz boş.</h5>
                </div>
            }
            else
            {
                @foreach (var post in Model)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-0 pt-3 pb-0 px-3">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center fw-bold me-2"
                                     style="width: 48px; height: 48px;">
                                    @(post.AuthorUser?.FirstName?.Substring(0, 1) ?? "U")
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark" style="font-size: 0.95rem;">
                                        @(post.AuthorUser?.FirstName ?? "Kullanıcı") @(post.AuthorUser?.LastName ?? "")
                                    </h6>
                                    <small class="text-muted" style="font-size: 0.75rem;">
                                        @post.CreatedDate.ToString("dd MMM") • <i class="fa-solid fa-earth-americas"></i>
                                    </small>
                                </div>
                                <div class="ms-auto">
                                    <button class="btn btn-link text-muted p-0"><i class="fa-solid fa-ellipsis"></i></button>
                                </div>
                            </div>
                        </div>

                        <div class="card-body px-3">
                            <a asp-action="Detail" asp-route-id="@post.PostId" class="text-decoration-none text-dark">
                                <h6 class="card-title fw-bold mb-2">@post.Title</h6>
                            </a>

                            <div class="card-text text-dark mb-3" style="font-size: 0.95rem; line-height: 1.5;">
                                @if (post.Content.Length > 200)
                                {
                                    @Html.Raw(post.Content.Substring(0, 200))
                                    <a asp-action="Detail" asp-route-id="@post.PostId" class="text-muted text-decoration-none fw-bold small">...devamını gör</a>
                                }
                                else
                                {
                                    @Html.Raw(post.Content)
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <a asp-action="Detail" asp-route-id="@post.PostId">
                                <img src="@post.ImageUrl" class="img-fluid w-100" style="max-height: 500px; object-fit: cover;" alt="Post Image">
                            </a>
                        }

                        <div class="card-footer bg-white border-top-0 pt-1 pb-2">
                            <hr class="my-2 text-muted opacity-25">
                            <div class="d-flex justify-content-between px-2">
                                
                                <form asp-action="Like" asp-route-id="@post.PostId" method="post" class="flex-grow-1">
                                    <button type="submit" class="btn btn-light bg-transparent border-0 w-100 text-secondary fw-bold">
                                        @if (post.IsLikedByCurrentUser)
                                        {
                                            <i class="fa-solid fa-heart me-2 text-danger"></i> <span class="text-danger">Beğendin (@post.LikeCount)</span>
                                        }
                                        else
                                        {
                                            <i class="fa-regular fa-heart me-2"></i> <span>Beğen (@post.LikeCount)</span>
                                        }
                                    </button>
                                </form>

                                <a asp-action="Detail" asp-route-id="@post.PostId" class="btn btn-light bg-transparent border-0 text-secondary fw-bold flex-grow-1 text-decoration-none text-center">
                                    <i class="fa-regular fa-comment me-2"></i> Yorum Yap (@(post.Comments?.Count ?? 0))
                                </a>

                                <button class="btn btn-light bg-transparent border-0 text-secondary fw-bold flex-grow-1">
                                    <i class="fa-solid fa-share-nodes me-2"></i> Paylaş
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-lg-3 d-none d-lg-block">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold text-secondary mb-3" style="font-size: 0.8rem;">GÜNDEMDEKİLER</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><a href="#" class="text-dark text-decoration-none fw-bold small">#Mezuniyet2026</a></li>
                        <li class="mb-2"><a href="#" class="text-dark text-decoration-none fw-bold small">#YazılımMülakatları</a></li>
                        <li><a href="#" class="text-dark text-decoration-none fw-bold small">#RemoteÇalışma</a></li>
                    </ul>
                </div>
            </div>

            <div class="text-center mt-3 small text-muted">
                &copy; 2026 MezunPort
            </div>
        </div>
    </div>
</div>