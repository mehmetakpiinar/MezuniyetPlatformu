@model IEnumerable<MezuniyetPlatformu.Web.ViewModels.ExperiencePostViewModel>
@{
    ViewData["Title"] = "Deneyim Paylaşımları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-white border-bottom py-5 mb-5">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold text-dark mb-2">💡 Mezun Deneyimleri</h1>
            <p class="text-muted mb-0">Mülakat süreçleri, staj anıları ve kariyer tavsiyeleri.</p>
        </div>

        @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Ogrenci") || User.IsInRole("Mezun")))
        {
            <a asp-controller="ExperiencePosts" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fa-solid fa-pen-to-square me-2"></i> Deneyim Paylaş
            </a>
        }
    </div>
</div>

<div class="container">

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger shadow-sm border-0 rounded-3" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewBag.ErrorMessage
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="fa-regular fa-folder-open fa-2x text-muted"></i>
            </div>
            <h4 class="text-muted">Henüz paylaşım yapılmamış.</h4>
            <p class="text-secondary">İlk deneyimi sen paylaşarak topluluğa katkıda bulunabilirsin.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var post in Model)
            {
                <div class="col-lg-6">
                    <div class="card h-100 border-0 shadow-sm hover-lift p-3">
                        <div class="card-body">

                            <div class="d-flex align-items-center mb-3">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold me-3 flex-shrink-0"
                                     style="width: 45px; height: 45px; font-size: 1.2rem;">
                                    @(post.AuthorUser?.FirstName?.Substring(0, 1) ?? "U")
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark">
                                        @(post.AuthorUser?.FirstName ?? "Anonim") @(post.AuthorUser?.LastName ?? "")
                                    </h6>
                                    <small class="text-muted" style="font-size: 0.8rem;">
                                        @post.CreatedDate.ToShortDateString() tarihinde paylaşıldı
                                    </small>
                                </div>
                            </div>

                            <h4 class="card-title fw-bold mb-3">
                                <a asp-controller="ExperiencePosts" asp-action="Detail" asp-route-id="@post.PostId" class="text-dark text-decoration-none stretched-link">
                                    @post.Title
                                </a>
                            </h4>

                            <p class="card-text text-secondary" style="line-height: 1.6;">
                                @if (post.Content.Length > 120)
                                {
                                    @post.Content.Substring(0, 120)
                        
                                    <span class="text-muted">...</span>
                                }
                                else
                                {
                                    @post.Content
                                }
                            </p>

                            <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="badge bg-light text-primary border">Deneyim</span>
                                <small class="text-primary fw-bold">Devamını Oku &rarr;</small>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>