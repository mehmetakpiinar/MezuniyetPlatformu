@model MezuniyetPlatformu.Web.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profili Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning">
                    <h4 class="mb-0 text-dark">Bilgilerini Güncelle</h4>
                </div>
                <div class="card-body">

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="ProfileId" />
                        <input type="hidden" asp-for="UserId" />

                        <div class="mb-3">
                            <label asp-for="ProfilePhotoURL" class="form-label fw-bold"></label>
                            <input asp-for="ProfilePhotoURL" class="form-control" placeholder="https://..." />
                            <span asp-validation-for="ProfilePhotoURL" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StudyProgram" class="form-label fw-bold"></label>
                                <input asp-for="StudyProgram" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="GraduationYear" class="form-label fw-bold"></label>
                                <input asp-for="GraduationYear" class="form-control" type="number" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="About" class="form-label fw-bold"></label>
                            <textarea asp-for="About" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="LinkedInURL" class="form-label fw-bold"></label>
                                <input asp-for="LinkedInURL" class="form-control" placeholder="LinkedIn Profil Linki" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="GitHubURL" class="form-label fw-bold"></label>
                                <input asp-for="GitHubURL" class="form-control" placeholder="GitHub Profil Linki" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-bold"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">İptal</a>
                            <button type="submit" class="btn btn-success px-4">Değişiklikleri Kaydet</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}