@model MezuniyetPlatformu.Web.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profilim";
    Layout = "~/Views/Shared/_Layout.cshtml";
    // Kullanıcının rolünü kontrol ediyoruz
    bool isEmployer = User.IsInRole("Isveren");
}

<style>
    .profile-banner {
        height: 180px;
        background: @(isEmployer ? "linear-gradient(135deg, #2c3e50, #4ca1af)" : "linear-gradient(135deg, #0d6efd, #0dcaf0)");
        border-radius: 0 0 10px 10px;
        position: relative;
    }

    .profile-pic-container {
        position: absolute;
        bottom: -50px;
        left: 30px;
        padding: 4px;
        background: white;
        border-radius: 50%;
    }

    .profile-pic {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #fff;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
</style>

<div class="container mb-5">
    <div class="card border-0 shadow-sm mb-4 overflow-visible">
        <div class="profile-banner">
            <div class="profile-pic-container">
                <img src="@(string.IsNullOrEmpty(Model?.ProfilePhotoURL) ? "/uploads/defaults/user-placeholder.png" : Model.ProfilePhotoURL)" class="profile-pic">
            </div>
        </div>
        <div class="card-body pt-5 pb-4 px-4">
            <div class="d-flex justify-content-between align-items-end mt-3 flex-wrap">
                <div class="ms-md-2">
                    <h2 class="fw-bold mb-0">
                        @(Model?.User?.FirstName) @(Model?.User?.LastName)
                        @if (isEmployer)
                        {
                            <i class="fa-solid fa-briefcase text-secondary fs-5 ms-2" title="İşveren Hesabı"></i>
                        }
                        else
                        {

                            <i class="fa-solid fa-circle-check text-info fs-5 ms-2" title="Öğrenci Hesabı"></i>
                        }
                    </h2>

                    @if (isEmployer)
                    {
                        <p class="text-muted mb-1 fw-bold">
                            @(Model?.UniversityName ?? "Şirket Adı Yok")
                        </p>
                        <span class="badge bg-secondary text-white"><i class="fa-solid fa-building me-1"></i> @(Model?.StudyProgram ?? "Sektör")</span>
                    }
                    else
                    {
                        <p class="text-muted mb-1">
                            @(Model?.StudyProgram ?? "Bölüm") | @(Model?.UniversityName ?? "Üniversite")
                        </p>
                        <span class="badge bg-light text-dark border"><i class="fa-solid fa-location-dot me-1 text-danger"></i> Türkiye</span>
                    }
                </div>
                <div class="mt-3 mt-md-0 d-flex gap-2">
                    @if (!isEmployer)
                    {
                        <a asp-controller="Cv" asp-action="Index" class="btn btn-outline-dark fw-bold rounded-pill">
                            <i class="fa-solid fa-download me-2"></i>CV İndir
                        </a>
                    }
                    <a asp-action="Edit" class="btn btn-primary fw-bold rounded-pill px-4"><i class="fa-solid fa-pen me-2"></i>Düzenle</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">İletişim</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3 d-flex align-items-center">
                            <div class="bg-light p-2 rounded-circle me-3"><i class="fa-solid fa-envelope text-primary"></i></div>
                            <div><small class="d-block text-muted">Email</small><span class="fw-bold text-dark text-break">@Model?.User?.Email</span></div>
                        </li>
                        <li class="mb-3 d-flex align-items-center">
                            <div class="bg-light p-2 rounded-circle me-3"><i class="fa-solid fa-phone text-success"></i></div>
                            <div><small class="d-block text-muted">Telefon</small><span class="fw-bold text-dark">@(Model?.PhoneNumber ?? "-")</span></div>
                        </li>
                        @if (isEmployer && !string.IsNullOrEmpty(Model?.LinkedInURL))
                        {
                            <li class="mb-3 d-flex align-items-center">
                                <div class="bg-light p-2 rounded-circle me-3"><i class="fa-solid fa-globe text-primary"></i></div>
                                <div><small class="d-block text-muted">Web Sitesi</small><a href="@Model.LinkedInURL" target="_blank">Siteye Git</a></div>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            @if (!isEmployer)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Yetenekler</h5>
                        @if (!string.IsNullOrEmpty(Model?.Skills))
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var skill in Model.Skills.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 border border-primary-subtle">@skill.Trim()</span>
                                }
                            </div>
                        }
                        else
                        {

                            <p class="text-muted small">Henüz yetenek eklenmemiş.</p>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">@(isEmployer ? "Şirket Hakkında" : "Hakkımda")</h5>
                    @if (!string.IsNullOrEmpty(Model?.About))
                    {
                        <div style="line-height: 1.8; color: #555;">@Html.Raw(Model.About)</div>
                    }
                    else
                    {
                        <div class="alert alert-light border text-center">
                            <p class="mb-0 text-muted">@(isEmployer ? "Şirket tanıtım yazısı ekleyin." : "Kendinizi tanıtan bir yazı ekleyin.")</p>
                        </div>
                    }
                </div>
            </div>

            @if (!isEmployer)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Eğitim Bilgileri</h5>
                        <div class="d-flex">
                            <div class="me-3 d-flex flex-column align-items-center">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    <i class="fa-solid fa-graduation-cap"></i>
                                </div>
                                <div class="h-100 border-start border-2 border-light my-2"></div>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">@Model?.UniversityName</h6>
                                <p class="text-primary mb-1 fw-bold">@Model?.StudyProgram</p>
                                <small class="text-muted"><i class="fa-regular fa-calendar me-1"></i> Mezuniyet: @(Model?.GraduationYear)</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>