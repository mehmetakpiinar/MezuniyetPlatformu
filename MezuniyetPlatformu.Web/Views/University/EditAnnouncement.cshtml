@model MezuniyetPlatformu.Entities.Announcement
@{
    ViewData["Title"] = "Duyuru Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark">
                    <i class="fa-solid fa-pen-to-square me-2 text-primary"></i>Duyuru Düzenle
                </h2>
                <a asp-action="MyAnnouncements" class="btn btn-outline-secondary rounded-pill">
                    <i class="fa-solid fa-arrow-left me-2"></i> Vazgeç
                </a>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger rounded-3 shadow-sm mb-4">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-lg-5">
                    <form asp-action="EditAnnouncement" method="post">
                        <input type="hidden" asp-for="AnnouncementId" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Duyuru Başlığı</label>
                            <input asp-for="Title" class="form-control form-control-lg bg-light border-0" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Mesaj İçeriği</label>
                            <textarea asp-for="Message" class="form-control bg-light border-0" rows="6" required></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold hover-scale">
                                <i class="fa-solid fa-floppy-disk me-2"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .hover-scale:hover {
        transform: translateY(-2px);
        transition: 0.2s;
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
</style>