@model List<MezuniyetPlatformu.Entities.Announcement>
@{
    ViewData["Title"] = "Duyurularım";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark"><i class="fa-solid fa-bullhorn me-2 text-warning"></i>Duyuru Geçmişi</h2>
            <p class="text-muted">Yayınladığınız tüm duyuruları buradan yönetebilirsiniz.</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill">
            <i class="fa-solid fa-arrow-left me-2"></i> Panele Dön
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 shadow-sm mb-4">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Başlık</th>
                            <th>Mesaj İçeriği</th>
                            <th>Tarih</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">@item.Title</td>
                                    <td class="text-muted small">
                                        @(item.Message.Length > 50 ? item.Message.Substring(0, 50) + "..." : item.Message)
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-secondary border">
                                            @item.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="EditAnnouncement" asp-route-id="@item.AnnouncementId"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3 hover-scale me-1">
                                            <i class="fa-solid fa-pen me-1"></i> Düzenle
                                        </a>

                                        <form asp-action="DeleteAnnouncement" asp-route-id="@item.AnnouncementId" method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 hover-scale">
                                                <i class="fa-solid fa-trash me-1"></i> Sil
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="text-muted opacity-50">
                                        <i class="fa-regular fa-folder-open fa-3x mb-3"></i>
                                        <p>Henüz yayınlanmış bir duyurunuz yok.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-scale:hover {
        transform: translateY(-2px);
        transition: 0.2s;
    }
</style>