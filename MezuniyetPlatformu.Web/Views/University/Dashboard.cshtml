@model MezuniyetPlatformu.Web.ViewModels.UniversityDashboardViewModel
@{
    ViewData["Title"] = "Üniversite Paneli";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="card border-0 shadow-sm mb-5 rounded-4 overflow-hidden">
        <div class="card-body p-4 d-flex align-items-center bg-white">
            @if (!string.IsNullOrEmpty(Model.UniversityLogo))
            {
                <img src="@Model.UniversityLogo" class="rounded-circle shadow-sm me-4 border p-1" width="80" height="80" style="object-fit: cover;">
            }
            else
            {
                <div class="rounded-circle shadow-sm me-4 border d-flex align-items-center justify-content-center bg-light text-secondary" style="width: 80px; height: 80px;">
                    <i class="fa-solid fa-building-columns fa-2x"></i>
                </div>
            }
            <div>
                <h6 class="text-primary fw-bold text-uppercase ls-1 mb-1">Yönetim Paneli</h6>
                <h2 class="fw-bold text-dark m-0">@Model.UniversityName</h2>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <a href="/University/MyStudents" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 hover-lift stats-card border-primary-left">
                    <div class="card-body p-4 d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted fw-bold small text-uppercase mb-1">Toplam Öğrenci</p>
                            <h2 class="display-4 fw-bold text-dark mb-0">@Model.TotalStudents</h2>
                            <span class="badge bg-primary bg-opacity-10 text-primary mt-2">
                                <i class="fa-solid fa-check me-1"></i> Aktif Kayıt
                            </span>
                        </div>
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="fa-solid fa-user-graduate fa-2x"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 stats-card border-success-left">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div>
                            <p class="text-muted fw-bold small text-uppercase mb-1">İşe Yerleşen Mezun</p>
                            <h2 class="display-4 fw-bold text-dark mb-0">@Model.EmployedGraduates</h2>
                        </div>
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="fa-solid fa-briefcase fa-2x"></i>
                        </div>
                    </div>

                    @{
                        var rate = Model.TotalStudents > 0 ? (Model.EmployedGraduates * 100 / Model.TotalStudents) : 0;
                    }
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>İstihdam Oranı</span>
                        <span class="fw-bold text-success">%@rate</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @rate%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 border-bottom d-flex align-items-center justify-content-between px-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="fa-solid fa-bullhorn fa-lg"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold m-0 text-dark">Duyuru Oluştur</h5>
                            <small class="text-muted">Tüm öğrencilerinize anında bildirim gönderin.</small>
                        </div>
                    </div>

                    <a asp-action="MyAnnouncements" class="btn btn-light rounded-pill text-muted fw-bold small px-3">
                        <i class="fa-solid fa-clock-rotate-left me-2"></i>Geçmiş Duyurular
                    </a>
                </div>

                <div class="card-body p-4 p-lg-5 bg-light bg-opacity-25">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center mb-4">
                            <i class="fa-solid fa-check-circle fa-xl me-3"></i>
                            <div>@TempData["SuccessMessage"]</div>
                        </div>
                    }

                    <form asp-action="SendAnnouncement" method="post">
                        <div class="row g-4">
                            <div class="col-12">
                                <label class="form-label fw-bold text-dark">Duyuru Başlığı</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-0"><i class="fa-solid fa-heading text-muted"></i></span>
                                    <input type="text" name="title" class="form-control form-control-lg border-0" placeholder="Örn: Bahar Dönemi Staj Başvuruları" required>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold text-dark">Mesaj İçeriği</label>
                                <textarea name="message" class="form-control border-0 shadow-sm p-3" rows="5" placeholder="Öğrencilerinize iletmek istediğiniz detayları buraya yazın..." required></textarea>
                            </div>
                            <div class="col-12 d-flex justify-content-end pt-2">
                                <button class="btn btn-primary px-5 py-3 rounded-pill fw-bold shadow hover-scale d-flex align-items-center">
                                    <span>Yayınla</span>
                                    <i class="fa-regular fa-paper-plane ms-2"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Kartların üzerine gelince hafifçe yukarı kalkması için */
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    /* İstatistik kartları için sol kenar çizgisi */
    .border-primary-left {
        border-left: 5px solid #0d6efd !important;
    }

    .border-success-left {
        border-left: 5px solid #198754 !important;
    }

    /* İkon yuvarlakları */
    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Genel buton efekti */
    .hover-scale:hover {
        transform: scale(1.02);
        transition: 0.2s;
    }
</style>