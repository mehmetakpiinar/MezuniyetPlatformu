@{
    ViewData["Title"] = "Kariyerin Buradan Başlar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero-section text-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h1 class="hero-title">
                    Hayalindeki Kariyeri <br />
                    <span style="color: #ffce67;">Mezuniyet Platformu</span> ile Başlat!
                </h1>
                <p class="hero-subtitle">
                    Öğrenciler, mezunlar ve sektörün lider şirketleri tek bir çatı altında.
                    Staj bul, işe başvur, deneyimlerini paylaş ve networkünü genişlet.
                </p>

                <form action="/JobPosts/Index" method="get">
                    <div class="search-box-container">
                        <input type="text" class="search-input" placeholder="Pozisyon, şirket veya anahtar kelime ara...">
                        <button type="submit" class="btn btn-primary search-btn">
                            <i class="fa-solid fa-magnifying-glass me-2"></i> İŞ ARA
                        </button>
                    </div>
                </form>

                <div class="mt-4 text-white-50">
                    Popüler aramalar:
                    <a href="#" class="text-white text-decoration-underline me-2">Yazılım Mühendisi</a>
                    <a href="#" class="text-white text-decoration-underline me-2">Stajyer</a>
                    <a href="#" class="text-white text-decoration-underline">Veri Analisti</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container stats-container mb-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-briefcase"></i></div>
                <div class="stat-number">500+</div>
                <div class="text-muted">Aktif İş İlanı</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-building"></i></div>
                <div class="stat-number">120+</div>
                <div class="text-muted">Kayıtlı Şirket</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-user-graduate"></i></div>
                <div class="stat-number">1000+</div>
                <div class="text-muted">Öğrenci & Mezun</div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="text-center mb-5">
        <h6 class="text-primary fw-bold text-uppercase">Süreç Nasıl İşliyor?</h6>
        <h2 class="fw-bold">Kariyer Yolculuğun 3 Adımda Başlasın</h2>
    </div>

    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="p-4">
                <div class="step-circle">1</div>
                <h4>Profilini Oluştur</h4>
                <p class="text-muted">Eğitim bilgilerini, yeteneklerini ve projelerini ekleyerek profesyonel bir profil oluştur.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-4">
                <div class="step-circle">2</div>
                <h4>İlanlara Başvur</h4>
                <p class="text-muted">Yüzlerce aktif iş ve staj ilanını incele, sana en uygun olana tek tıkla başvur.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-4">
                <div class="step-circle">3</div>
                <h4>İletişime Geç</h4>
                <p class="text-muted">İşverenlerle doğrudan mesajlaş, mülakat süreçlerini yönet ve işi kap!</p>
            </div>
        </div>
    </div>
</div>

@if (!User.Identity.IsAuthenticated)
{
    <div class="container my-5">
        <div class="card bg-primary text-white border-0 rounded-3 overflow-hidden">
            <div class="card-body p-5 text-center position-relative">
                <h2 class="fw-bold mb-3">Hala Aramıza Katılmadın mı?</h2>
                <p class="lead mb-4">Kariyer fırsatlarını kaçırmamak için hemen ücretsiz üye ol.</p>
                <a asp-controller="Auth" asp-action="Register" class="btn btn-light btn-lg px-5 rounded-pill fw-bold text-primary">
                    Hemen Kayıt Ol
                </a>
            </div>
        </div>
    </div>
}