@model List<MezuniyetPlatformu.Entities.Announcement>
@{
    ViewData["Title"] = "Üniversite Duyuruları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="d-flex align-items-center mb-4">
                <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3 me-3">
                    <i class="fa-solid fa-bullhorn fa-2x"></i>
                </div>
                <div>
                    <h2 class="fw-bold text-dark m-0">Duyurular</h2>
                    <p class="text-muted m-0">Üniversitenizden gelen son haberler ve etkinlikler.</p>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model)
                    {
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden hover-shadow transition-all">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="fw-bold text-primary mb-0">@item.Title</h5>
                                    <span class="badge bg-light text-secondary border">
                                        <i class="fa-regular fa-clock me-1"></i> @item.CreatedDate.ToString("dd.MM.yyyy")
                                    </span>
                                </div>
                                <p class="text-secondary mb-0" style="line-height: 1.6;">
                                    @item.Message
                                </p>
                            </div>
                            <div class="position-absolute top-0 start-0 bottom-0 bg-primary" style="width: 4px;"></div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 border rounded-4 bg-light border-dashed">
                    <i class="fa-regular fa-bell-slash fa-3x text-muted opacity-50 mb-3"></i>
                    <h5 class="fw-bold text-muted">Henüz Duyuru Yok</h5>
                    <p class="text-secondary small">Üniversiteniz henüz bir duyuru yayınlamadı.</p>
                </div>
            }

        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .border-dashed {
        border-style: dashed !important;
    }
</style>