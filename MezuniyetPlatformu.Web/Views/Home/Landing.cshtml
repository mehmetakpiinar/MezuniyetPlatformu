@{
    ViewData["Title"] = "Geleceğini Şekillendir";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="position-relative overflow-hidden" style="background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%); border-radius: 0 0 50px 50px;">
    <div class="position-absolute top-0 start-0 w-100 h-100" style="opacity: 0.1; background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 30px 30px;"></div>

    <div class="container position-relative" style="padding: 100px 0 120px 0;">
        <div class="row align-items-center">
            <div class="col-lg-7 text-white">
                <span class="badge bg-white text-primary mb-3 px-3 py-2 rounded-pill fw-bold shadow-sm">🚀 Kariyerine Roket Tak</span>
                <h1 class="display-3 fw-bold mb-4" style="line-height: 1.2;">
                    Hayalindeki İş <br>Bir Tık Uzakta.
                </h1>
                <p class="lead mb-5 opacity-75" style="max-width: 500px;">
                    Mezuniyet Platformu ile binlerce şirket ve yetenekli mezun tek bir çatı altında buluşuyor. Stajını bul, işini kap, geleceğini kur.
                </p>

                <div class="bg-white p-2 rounded-4 shadow-lg d-flex flex-wrap flex-md-nowrap align-items-center gap-2" style="max-width: 600px;">
                    <div class="input-group border-0">
                        <span class="input-group-text bg-transparent border-0 text-muted"><i class="fa-solid fa-search"></i></span>
                        <input type="text" class="form-control border-0 bg-transparent shadow-none" placeholder="Hangi pozisyonu arıyorsun?">
                    </div>
                    <div class="vr d-none d-md-block mx-2"></div>
                    <button class="btn btn-primary px-4 py-3 rounded-3 fw-bold w-100 w-md-auto">
                        İŞ BUL
                    </button>
                </div>

                <div class="mt-4 pt-3 d-flex gap-4 opacity-75 small">
                    <div><i class="fa-solid fa-check-circle me-1"></i> Ücretsiz Üyelik</div>
                    <div><i class="fa-solid fa-check-circle me-1"></i> 500+ Şirket</div>
                    <div><i class="fa-solid fa-check-circle me-1"></i> Onaylı İlanlar</div>
                </div>
            </div>

            <div class="col-lg-5 d-none d-lg-block text-center">
                <img src="https://cdni.iconscout.com/illustration/premium/thumb/job-search-2644414-2206504.png"
                     alt="Kariyer" class="img-fluid floating-anim" style="max-width: 100%; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.2));">
            </div>
        </div>
    </div>
</div>

<div class="container" style="margin-top: -60px; position: relative; z-index: 10;">
    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
            <div class="card border-0 shadow text-center p-4 h-100">
                <div class="mb-3 text-primary display-5">
                    <i class="fa-solid fa-briefcase"></i>
                </div>
                <h3 class="fw-bold">500+</h3>
                <p class="text-muted mb-0">Aktif İş İlanı</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow text-center p-4 h-100">
                <div class="mb-3 text-success display-5">
                    <i class="fa-solid fa-building"></i>
                </div>
                <h3 class="fw-bold">120+</h3>
                <p class="text-muted mb-0">Kurumsal Şirket</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow text-center p-4 h-100">
                <div class="mb-3 text-warning display-5">
                    <i class="fa-solid fa-users"></i>
                </div>
                <h3 class="fw-bold">10k+</h3>
                <p class="text-muted mb-0">Öğrenci & Mezun</p>
            </div>
        </div>
    </div>
</div>

<div class="container py-5 my-5">
    <div class="text-center mb-5">
        <span class="text-primary fw-bold text-uppercase small ls-2">Süreç Nasıl İşliyor?</span>
        <h2 class="fw-bold display-6 mt-2">Kariyer Yolculuğun 3 Adımda Başlasın</h2>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="p-4 hover-scale">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                    <i class="fa-solid fa-id-card fa-2x"></i>
                </div>
                <h4>1. Profilini Oluştur</h4>
                <p class="text-muted">Eğitim bilgilerini ve yeteneklerini ekle, seni en iyi yansıtan profili hazırla.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 hover-scale">
                <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                    <i class="fa-solid fa-paper-plane fa-2x"></i>
                </div>
                <h4>2. İlanlara Başvur</h4>
                <p class="text-muted">Sana uygun iş ve staj ilanlarını filtrele, tek tıkla başvurunu yap.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 hover-scale">
                <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                    <i class="fa-solid fa-comments fa-2x"></i>
                </div>
                <h4>3. İletişime Geç</h4>
                <p class="text-muted">İşverenlerle mesajlaş, mülakatlarını yönet ve hayalindeki işe başla.</p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Ufak bir animasyon ekleyelim */
    @@keyframes floating {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    .floating-anim {
        animation: floating 4s ease-in-out infinite;
    }
</style>