@model List<MezuniyetPlatformu.Web.ViewModels.JobApplicationViewModel>
@{
    ViewData["Title"] = "İlan Başvuruları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>İlana Gelen Başvurular</h2>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Henüz bu ilana kimse başvurmamış.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Başvuran Adı Soyadı</th>
                        <th>E-Posta</th>
                        <th>Başvuru Tarihi</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model)
                    {
                        <tr>
                            <td>
                                @(app.CandidateUser?.FirstName) @(app.CandidateUser?.LastName)
                            </td>
                            <td>
                                <a href="mailto:@(app.CandidateUser?.Email)">@app.CandidateUser?.Email</a>
                            </td>
                            <td>@app.ApplicationDate.ToShortDateString()</td>
                            <td>
                                <span class="badge bg-info text-dark">@app.Status</span>
                            </td>
                            <td>
                                <a asp-controller="Messages"
                                   asp-action="Chat"
                                   asp-route-userId="@app.CandidateUserId"
                                   class="btn btn-primary btn-sm">
                                    💬 Mesaj Gönder
                                </a>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">&larr; İlanlara Dön</a>
    </div>
</div>