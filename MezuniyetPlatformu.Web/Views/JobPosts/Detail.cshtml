@model MezuniyetPlatformu.Web.ViewModels.JobPostsViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="fw-bold text-dark display-6 mb-2">@Model.Title</h1>

                    <div class="d-flex flex-wrap gap-3 text-muted mb-3">
                        <span class="d-flex align-items-center">
                            <div class="bg-light rounded-circle p-1 me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="fa-solid fa-building text-primary small"></i>
                            </div>
                            <span>Şirket Adı</span>
                        </span>
                        <span class="d-flex align-items-center">
                            <div class="bg-light rounded-circle p-1 me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="fa-solid fa-location-dot text-danger small"></i>
                            </div>
                            <span>@(Model.Location ?? "Konum Belirtilmemiş")</span>
                        </span>
                        <span class="d-flex align-items-center">
                            <div class="bg-light rounded-circle p-1 me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="fa-regular fa-clock text-success small"></i>
                            </div>
                            <span>@Model.PublishedDate.ToString("dd MMMM yyyy")</span>
                        </span>
                    </div>

                    <div>
                        @if (Model.JobType == "Uzaktan")
                        {
                            <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill">
                                <i class="fa-solid fa-wifi me-1"></i> Remote
                            </span>
                        }
                        else if (Model.JobType == "Staj")
                        {
                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle px-3 py-2 rounded-pill">
                                <i class="fa-solid fa-graduation-cap me-1"></i> Staj
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle px-3 py-2 rounded-pill">
                                @Model.JobType
                            </span>
                        }
                    </div>
                </div>

                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (!User.IsInRole("Isveren"))
                        {
                            <form asp-controller="JobPosts" asp-action="Apply" asp-route-id="@Model.JobPostId" method="post" class="d-grid gap-2 d-md-block">
                                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm hover-lift w-100 w-md-auto">
                                    <i class="fa-solid fa-paper-plane me-2"></i> Hemen Başvur
                                </button>

                                <a asp-controller="Messages" asp-action="Chat" asp-route-userId="@Model.EmployerProfile?.UserId"
                                   class="btn btn-outline-primary btn-lg rounded-pill px-4 fw-bold ms-md-2 w-100 w-md-auto mt-2 mt-md-0">
                                    <i class="fa-regular fa-comment-dots"></i>
                                </a>
                            </form>
                        }
                        else
                        {
                            <div class="d-inline-block text-start bg-light border rounded-3 p-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-white p-2 rounded-circle shadow-sm me-3 text-primary">
                                        <i class="fa-solid fa-user-tie fa-lg"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold m-0 text-dark">İşveren Modu</h6>
                                        <small class="text-muted" style="font-size: 0.85rem;">İşveren hesabıyla ilanlara başvurulamaz.</small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm w-100 w-md-auto">
                            <i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap ve Başvur
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="fw-bold m-0"><i class="fa-solid fa-align-left me-2 text-primary"></i>İş Tanımı & Detaylar</h5>
                </div>
                <div class="card-body p-4 p-lg-5">
                    <div class="article-content text-dark" style="line-height: 1.8; font-size: 1.05rem;">
                        @Html.Raw(Model.Description)
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="fw-bold m-0">İlan Özeti</h6>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item p-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted small"><i class="fa-solid fa-briefcase me-2"></i>Çalışma Şekli</span>
                            <span class="fw-bold text-dark">@Model.JobType</span>
                        </li>
                        <li class="list-group-item p-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted small"><i class="fa-solid fa-calendar-days me-2"></i>Yayın Tarihi</span>
                            <span class="fw-bold text-dark">@Model.PublishedDate.ToShortDateString()</span>
                        </li>
                        @if (Model.Deadline.HasValue)
                        {
                            <li class="list-group-item p-3 d-flex justify-content-between align-items-center bg-danger bg-opacity-10">
                                <span class="text-danger small fw-bold"><i class="fa-regular fa-hourglass-half me-2"></i>Son Başvuru</span>
                                <span class="fw-bold text-danger">@Model.Deadline.Value.ToShortDateString()</span>
                            </li>
                        }
                        <li class="list-group-item p-3 d-flex justify-content-between align-items-center">
                            <span class="text-muted small"><i class="fa-solid fa-toggle-on me-2"></i>Durum</span>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </li>
                    </ul>
                </div>
            </div>

            <div class="d-grid">
                <a asp-action="Index" class="btn btn-light border fw-bold text-muted">
                    <i class="fa-solid fa-arrow-left me-2"></i> Tüm İlanlara Dön
                </a>
            </div>

        </div>
    </div>
</div>

<style>
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
    /* Mobilde butonların tam genişlik olması için */
    @@media (max-width: 991px) {
        .w-md-auto {
            width: 100% !important;
        }
    }
</style>