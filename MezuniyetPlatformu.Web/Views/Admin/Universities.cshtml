@model List<MezuniyetPlatformu.Web.ViewModels.UniversityViewModel>
@{
    ViewData["Title"] = "Üniversite Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark"><i class="fa-solid fa-building-columns me-2 text-primary"></i>Üniversiteler</h2>
            <p class="text-muted">Sisteme kayıtlı üniversiteleri yönetin.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-secondary me-2">
                <i class="fa-solid fa-arrow-left me-2"></i>Geri
            </a>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUniversityModal">
                <i class="fa-solid fa-plus me-2"></i>Yeni Üniversite Ekle
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success"><i class="fa-solid fa-check me-2"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Logo</th>
                            <th>Üniversite Adı</th>
                            <th class="text-center">Öğrenci Sayısı</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var uni in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        @if (!string.IsNullOrEmpty(uni.LogoUrl))
                                        {
                                            <img src="@uni.LogoUrl" class="rounded-circle border" width="40" height="40" style="object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-circle border d-flex align-items-center justify-content-center text-muted" style="width: 40px; height: 40px;">
                                                <i class="fa-solid fa-building-columns"></i>
                                            </div>
                                        }
                                    </td>
                                    <td class="fw-bold">@uni.Name</td>
                                    <td class="text-center"><span class="badge bg-info text-dark">@uni.StudentCount</span></td>
                                    <td class="text-end pe-4">
                                        <form asp-action="DeleteUniversity" asp-route-id="@uni.UniversityId" method="post" onsubmit="return confirm('Bu üniversiteyi silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger hover-scale">
                                                <i class="fa-solid fa-trash"></i> Sil
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">Henüz kayıtlı üniversite yok.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addUniversityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Yeni Üniversite Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <form asp-action="CreateUniversity" method="post">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Üniversite Adı</label>
                        <input type="text" name="Name" class="form-control" placeholder="Örn: Boğaziçi Üniversitesi" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Logo URL (Opsiyonel)</label>
                        <input type="text" name="LogoUrl" class="form-control" placeholder="https://...">
                        <small class="text-muted" style="font-size: 11px;">İnternetteki bir görselin adresini yapıştırın.</small>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary fw-bold">Kaydet ve Ekle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-scale:hover {
        transform: scale(1.05);
        transition: 0.2s;
    }
</style>