@model List<MezuniyetPlatformu.Web.ViewModels.EventViewModel>
@{
    ViewData["Title"] = "Etkinlikler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="fa-solid fa-calendar-days me-2 text-primary"></i>Etkinlik Takvimi</h2>
            <p class="text-muted m-0">Kariyer günleri, seminerler ve atölye çalışmaları.</p>
        </div>
        
        @if (User.IsInRole("UniversityRep"))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill fw-bold px-4 shadow-sm hover-lift">
                <i class="fa-solid fa-plus me-2"></i>Yeni Etkinlik
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded shadow-sm border border-light">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="fa-regular fa-calendar-xmark fa-2x text-muted opacity-50"></i>
            </div>
            <h4 class="text-dark fw-bold">Yaklaşan etkinlik bulunmuyor.</h4>
            <p class="text-secondary small">Yeni etkinlikler eklendiğinde burada görünecek.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 hover-lift overflow-hidden">
                        
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center text-muted border-bottom" style="height: 200px;">
                                    <div class="text-center opacity-25">
                                        <i class="fa-regular fa-image fa-3x mb-2"></i>
                                        <div class="small fw-bold">Görsel Yok</div>
                                    </div>
                                </div>
                            }
                            
                            <div class="position-absolute top-0 end-0 m-3 bg-white rounded shadow-sm text-center p-2 border" style="width: 60px; min-width: 60px;">
                                <span class="d-block fw-bold text-danger h4 m-0">@item.EventDate.Day</span>
                                <span class="d-block small text-uppercase fw-bold text-muted" style="font-size: 0.7rem;">@item.EventDate.ToString("MMM")</span>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <div class="mb-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill px-3">
                                    <i class="fa-regular fa-clock me-1"></i> @item.EventDate.ToString("HH:mm")
                                </span>
                            </div>

                            <h5 class="card-title fw-bold mb-2 text-dark text-truncate" title="@item.Title">@item.Title</h5>
                            
                            <p class="card-text text-muted small mb-3" style="min-height: 40px;">
                                @if (item.Description.Length > 90)
                                {
                                    @item.Description.Substring(0, 90) <span>...</span>
                                }
                                else
                                {
                                    @item.Description
                                }
                            </p>

                            <div class="d-flex align-items-center text-secondary small bg-light p-2 rounded">
                                <i class="fa-solid fa-location-dot me-2 text-danger"></i>
                                <span class="fw-bold text-truncate">@item.Location</span>
                            </div>
                        </div>
                        
                        <div class="card-footer bg-white border-0 pt-0 pb-4 px-4">
<a asp-controller="Events" asp-action="Detail" asp-route-id="@item.EventId" class="btn btn-outline-primary w-100 btn-sm rounded-pill fw-bold">
    Detayları İncele
</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-lift { transition: transform 0.2s, box-shadow 0.2s; }
    .hover-lift:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
</style>