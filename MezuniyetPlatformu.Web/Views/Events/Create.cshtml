@model MezuniyetPlatformu.Web.ViewModels.EventViewModel
@{
    ViewData["Title"] = "Etkinlik Oluştur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0 text-dark">Yeni Etkinlik Planla</h3>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill btn-sm">
                    <i class="fa-solid fa-arrow-left me-1"></i> Geri Dön
                </a>
            </div>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-calendar-plus me-2"></i> Etkinlik Detayları</h5>
                </div>

                <div class="card-body p-5 bg-white">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger shadow-sm mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
                        </div>
                    }
                    <div asp-validation-summary="All" class="alert alert-warning border-0 shadow-sm mb-4 small" style="display:none;"></div>
                    <form asp-action="Create" method="post" enctype="multipart/form-data">

                        <input type="hidden" asp-for="UniversityId" value="1" />

                        <div class="mb-4">
                            <label asp-for="ImageUpload" class="form-label fw-bold small text-uppercase ls-1">Etkinlik Afişi / Görseli</label>
                            <input asp-for="ImageUpload" type="file" class="form-control bg-light" accept="image/*" />
                            <span asp-validation-for="ImageUpload" class="text-danger small fw-bold"></span>
                            <div class="form-text text-muted small">Önerilen boyut: 1200x600px (Yatay)</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold small text-uppercase ls-1">Etkinlik Başlığı</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-heading text-muted"></i></span>
                                <input asp-for="Title" class="form-control bg-light border-start-0" placeholder="Örn: Kariyer Zirvesi 2024" />
                            </div>
                            <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="EventDate" class="form-label fw-bold small text-uppercase ls-1">Tarih ve Saat</label>
                                <input asp-for="EventDate" class="form-control bg-light" type="datetime-local" />
                                <span asp-validation-for="EventDate" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Location" class="form-label fw-bold small text-uppercase ls-1">Konum / Salon</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-location-dot text-muted"></i></span>
                                    <input asp-for="Location" class="form-control bg-light border-start-0" placeholder="Örn: Konferans Salonu A" />
                                </div>
                                <span asp-validation-for="Location" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Description" class="form-label fw-bold small text-uppercase ls-1">Etkinlik İçeriği</label>
                            <textarea asp-for="Description" class="form-control bg-light" rows="5" placeholder="Etkinlik hakkında detaylı bilgi verin..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small fw-bold"></span>
                        </div>

                        <hr class="my-4 opacity-25">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-light btn-lg px-4 border text-muted fw-bold">İptal</a>
                            <button type="submit" class="btn btn-success btn-lg px-5 fw-bold shadow-sm hover-scale">
                                <i class="fa-solid fa-check me-2"></i> Etkinliği Yayınla
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .ls-1 {
        letter-spacing: 1px;
    }

    .hover-scale:hover {
        transform: scale(1.02);
        transition: 0.2s;
    }

    .form-control:focus {
        box-shadow: none;
        border-color: var(--bs-primary);
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}