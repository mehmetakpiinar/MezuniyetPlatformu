@model List<MezuniyetPlatformu.Web.ViewModels.ConversationViewModel>
@{
    ViewData["Title"] = "Mesajlarım";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom p-4">
                    <h4 class="mb-0 fw-bold text-dark"><i class="fa-regular fa-comments me-2 text-primary"></i>Mesajlarım</h4>
                </div>

                <div class="list-group list-group-flush">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <a asp-action="Chat" asp-route-userId="@item.UserId" class="list-group-item list-group-item-action p-4 border-bottom hover-bg-light transition-all">
                                <div class="d-flex align-items-center">

                                    <div class="position-relative me-3">
                                        @if (!string.IsNullOrEmpty(item.ProfilePhotoUrl))
                                        {
                                            <img src="@item.ProfilePhotoUrl" class="rounded-circle object-fit-cover shadow-sm" width="60" height="60" alt="@item.FullName">
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold shadow-sm" style="width: 60px; height: 60px; font-size: 1.2rem;">
                                                @item.FullName.Substring(0, 1)
                                            </div>
                                        }

                                        @if (item.UnreadCount > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white">
                                                @item.UnreadCount
                                            </span>
                                        }
                                    </div>

                                    <div class="flex-grow-1 min-width-0">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <h6 class="mb-0 fw-bold text-dark text-truncate">@item.FullName</h6>
                                            <small class="text-muted ms-2" style="font-size: 0.8rem;">
                                                @if (item.LastMessageDate.Date == DateTime.Today)
                                                {
                                                    @item.LastMessageDate.ToString("HH:mm")
                                                }
                                                else
                                                {
                                                    @item.LastMessageDate.ToString("dd MMM")
                                                }
                                            </small>
                                        </div>

                                        <p class="mb-0 text-muted text-truncate @(item.UnreadCount > 0 ? "fw-bold text-dark" : "")" style="max-width: 90%;">
                                            @if (item.UnreadCount > 0)
                                            {
                                                <i class="fa-solid fa-circle text-primary me-1" style="font-size: 0.5rem;"></i>
                                            }
                                            @item.LastMessageContent
                                        </p>
                                    </div>

                                    <div class="ms-3 text-muted opacity-25">
                                        <i class="fa-solid fa-chevron-right"></i>
                                    </div>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                    <i class="fa-regular fa-comment-dots fa-3x text-muted opacity-50"></i>
                                </div>
                            </div>
                            <h5 class="fw-bold text-dark">Henüz mesajınız yok</h5>
                            <p class="text-muted mb-4">Diğer kullanıcılarla iletişime geçmek için profillerini ziyaret edebilirsiniz.</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 fw-bold">
                                Keşfetmeye Başla
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-bg-light:hover {
        background-color: #f8f9fa !important;
    }

    .transition-all {
        transition: all 0.2s ease;
    }

    .object-fit-cover {
        object-fit: cover;
    }
</style>